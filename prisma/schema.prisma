generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role             String    @default("CITIZEN")
  consentTimestamp DateTime?
  consentVersion   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  lawyerProfile LawyerProfile?
  appointments  Appointment[]  @relation("CitizenAppointments")
  // NextAuth relations
  accounts      Account[]
  sessions      Session[]

  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  reviews          Review[]
  caseNotes        CaseNote[]
  reviewedVerificationCases LawyerVerificationCase[] @relation("LawyerVerificationReviewedBy")
  reviewedTemplates         DocumentTemplate[]       @relation("TemplateReviewedBy")
  templateReviewLogs        TemplateReviewLog[]      @relation("TemplateReviewLogReviewedBy")
  reviewedFAQs              FAQ[]                    @relation("FAQReviewedBy")
  faqReviewLogs             FAQReviewLog[]           @relation("FAQReviewLogReviewedBy")
  reviewedGuides            GuideEntry[]             @relation("GuideReviewedBy")
  guideReviewLogs           GuideReviewLog[]         @relation("GuideReviewLogReviewedBy")
  reviewedRights            RightEntry[]             @relation("RightReviewedBy")
  rightReviewLogs           RightReviewLog[]         @relation("RightReviewLogReviewedBy")
  reviewedLegalActs         LegalAct[]               @relation("LegalActReviewedBy")
  legalActReviewLogs        LegalActReviewLog[]      @relation("LegalActReviewLogReviewedBy")
  reviewedLawSections       LawSection[]             @relation("LawSectionReviewedBy")
  lawSectionReviewLogs      LawSectionReviewLog[]    @relation("LawSectionReviewLogReviewedBy")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model LawyerProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  city              String
  state             String?
  experienceYears   Int
  rating            Float    @default(0.0)
  reviewCount       Int      @default(0)
  consultationFee   Float
  profileViews      Int      @default(0)
  isVerified        Boolean  @default(false)
  barCouncilID      String?  @unique
  bio               String?  @db.Text
  subscriptionTier  String?  @default("BASIC") // BASIC, PRO, ELITE
  subscriptionExpiry DateTime?

  languages         Language[]
  specializations   Specialization[]
  translations      LawyerProfileTranslation[]
  modes             LawyerConsultationMode[]
  availabilitySlots AvailabilitySlot[]
  availabilityExceptions AvailabilityDateException[]
  availabilitySlotOverrides AvailabilitySlotOverride[]
  verificationDocuments VerificationDocument[]
  verificationCases LawyerVerificationCase[]
  appointments      Appointment[] @relation("LawyerAppointments")
  reviews           Review[]      @relation("LawyerReviews")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Language {
  id           String                @id @default(cuid())
  name         String                @unique
  lawyers      LawyerProfile[]
  translations LanguageTranslation[]
}

model Specialization {
  id           String                       @id @default(cuid())
  name         String                       @unique
  description  String?
  lawyers      LawyerProfile[]
  translations SpecializationTranslation[]
}

model LawyerConsultationMode {
  id              String        @id @default(cuid())
  mode            String
  lawyerProfileId String
  lawyerProfile   LawyerProfile @relation(fields: [lawyerProfileId], references: [id], onDelete: Cascade)

  @@unique([mode, lawyerProfileId])
}

model AvailabilitySlot {
  id              String        @id @default(cuid())
  lawyerProfileId String
  weekday         Int
  time            String
  lawyerProfile   LawyerProfile @relation(fields: [lawyerProfileId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([lawyerProfileId, weekday, time])
  @@index([lawyerProfileId, weekday])
}

model AvailabilityDateException {
  id              String        @id @default(cuid())
  lawyerProfileId String
  dateKey         String
  lawyerProfile   LawyerProfile @relation(fields: [lawyerProfileId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([lawyerProfileId, dateKey])
  @@index([lawyerProfileId, dateKey])
}

model AvailabilitySlotOverride {
  id              String        @id @default(cuid())
  lawyerProfileId String
  dateKey         String
  time            String
  action          String
  lawyerProfile   LawyerProfile @relation(fields: [lawyerProfileId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([lawyerProfileId, dateKey, time])
  @@index([lawyerProfileId, dateKey, action])
}

model VerificationDocument {
  id              String        @id @default(cuid())
  lawyerProfileId String
  kind            String
  fileName        String
  mimeType        String
  sizeBytes       Int
  storageProvider String        @default("DATABASE")
  storageBucket   String?
  storagePath     String?
  data            Bytes?
  lawyerProfile   LawyerProfile @relation(fields: [lawyerProfileId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([lawyerProfileId, kind, createdAt])
}

model Appointment {
  id                String        @id @default(cuid())
  citizenId         String
  lawyerId          String
  date              DateTime
  status            String        @default("PENDING")
  mode              String
  notes             String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  paymentStatus     String        @default("UNPAID")
  amount            Float?
  payoutStatus      String?       @default("PENDING") // PENDING, ELIGIBLE, SETTLED, DISPUTED
  citizen           User          @relation("CitizenAppointments", fields: [citizenId], references: [id])
  lawyer            LawyerProfile @relation("LawyerAppointments", fields: [lawyerId], references: [id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  messages          Message[]
  review            Review?
  caseNotes         CaseNote[] @relation("AppointmentCaseNotes")
}

model Message {
  id            String       @id @default(cuid())
  text          String       @db.Text
  senderId      String
  receiverId    String
  appointmentId String?
  fileUrl       String?      @db.Text
  fileName      String?
  createdAt     DateTime     @default(now())

  sender        User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver      User         @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([appointmentId])
}

model Review {
  id            String       @id @default(cuid())
  rating        Int
  comment       String?      @db.Text
  isDisputed    Boolean      @default(false)
  createdAt     DateTime     @default(now())

  appointmentId String       @unique
  lawyerId      String
  citizenId     String

  appointment   Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  lawyer        LawyerProfile @relation("LawyerReviews", fields: [lawyerId], references: [id], onDelete: Cascade)
  citizen       User         @relation(fields: [citizenId], references: [id], onDelete: Cascade)

  @@index([lawyerId])
  @@index([citizenId])
}

model CaseNote {
  id            String       @id @default(cuid())
  text          String       @db.Text
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  appointmentId String
  lawyerId      String

  appointment   Appointment  @relation("AppointmentCaseNotes", fields: [appointmentId], references: [id], onDelete: Cascade)
  lawyer        User         @relation(fields: [lawyerId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

model FAQCategory {
  id           String                   @id @default(cuid())
  name         String                   @unique
  description  String?
  faqs         FAQ[]
  translations FAQCategoryTranslation[]
}

model FAQ {
  id              String           @id @default(cuid())
  question        String
  answer          String
  categoryId      String
  category        FAQCategory      @relation(fields: [categoryId], references: [id])
  editorialStatus String           @default("REVIEW")
  reviewerNotes   String?          @db.Text
  reviewedAt      DateTime?
  reviewedById    String?
  reviewedBy      User?            @relation("FAQReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  translations    FAQTranslation[]
  reviewLogs      FAQReviewLog[]
}

model GuideEntry {
  id                String         @id @default(cuid())
  slug              String         @unique
  title             String
  category          String
  readTime          Int?
  hasPublishedContent Boolean      @default(false)
  editorialStatus   String         @default("DRAFT")
  reviewerNotes     String?        @db.Text
  reviewedAt        DateTime?
  reviewedById      String?
  reviewedBy        User?          @relation("GuideReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  reviewLogs        GuideReviewLog[]

  @@index([editorialStatus, updatedAt])
}

model RightEntry {
  id              String          @id @default(cuid())
  slug            String          @unique
  title           String
  editorialStatus String          @default("REVIEW")
  reviewerNotes   String?         @db.Text
  reviewedAt      DateTime?
  reviewedById    String?
  reviewedBy      User?           @relation("RightReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  reviewLogs      RightReviewLog[]

  @@index([editorialStatus, updatedAt])
}

model LegalAct {
  id                String              @id @default(cuid())
  slug              String              @unique
  shortCode         String              @unique
  title             String
  description       String              @db.Text
  sourceAuthority   String?
  sourceUrl         String?             @db.Text
  sourcePdfUrl      String?             @db.Text
  editorialStatus   String              @default("REVIEW")
  reviewerNotes     String?             @db.Text
  reviewedAt        DateTime?
  reviewedById      String?
  reviewedBy        User?               @relation("LegalActReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  sections          LawSection[]
  versions          LegalActVersion[]
  issueTopics       LegalIssueTopic[]
  outgoingRelations LegalActRelation[]  @relation("LegalActRelationFrom")
  incomingRelations LegalActRelation[]  @relation("LegalActRelationTo")
  reviewLogs        LegalActReviewLog[]
  timelineEvents    LegalActTimelineEvent[]

  @@index([editorialStatus, updatedAt])
}

model LawSection {
  id                 String               @id @default(cuid())
  actId              String
  act                LegalAct             @relation(fields: [actId], references: [id], onDelete: Cascade)
  sectionKey         String
  title              String
  sectionText        String               @db.Text
  plainEnglish       String               @db.Text
  punishmentSummary  String?              @db.Text
  practicalGuidance  String?              @db.Text
  exampleScenario    String?              @db.Text
  editorialStatus    String               @default("REVIEW")
  reviewerNotes      String?              @db.Text
  reviewedAt         DateTime?
  reviewedById       String?
  reviewedBy         User?                @relation("LawSectionReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  aliases            LawSectionAlias[]
  issueTopics        LegalIssueTopic[]
  outgoingCrosswalks LawSectionCrosswalk[] @relation("LawSectionCrosswalkFrom")
  incomingCrosswalks LawSectionCrosswalk[] @relation("LawSectionCrosswalkTo")
  reviewLogs         LawSectionReviewLog[]
  historyEntries     LawSectionHistoryEntry[]

  @@unique([actId, sectionKey])
  @@index([editorialStatus, updatedAt])
  @@index([actId, editorialStatus])
}

model LegalActVersion {
  id                String    @id @default(cuid())
  actId             String
  act               LegalAct  @relation(fields: [actId], references: [id], onDelete: Cascade)
  versionLabel      String
  status            String    @default("IN_FORCE")
  commencementDate  DateTime?
  effectiveFrom     DateTime?
  effectiveTo       DateTime?
  updateSummary     String?   @db.Text
  officialSourceUrl String?   @db.Text
  officialPdfUrl    String?   @db.Text
  isCurrent         Boolean   @default(false)
  displayOrder      Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([actId, versionLabel])
  @@index([actId, isCurrent, displayOrder])
}

model LegalActTimelineEvent {
  id           String    @id @default(cuid())
  actId        String
  act          LegalAct  @relation(fields: [actId], references: [id], onDelete: Cascade)
  title        String
  summary      String?   @db.Text
  eventType    String
  eventDate    DateTime?
  sourceLabel  String?
  sourceUrl    String?   @db.Text
  sourcePdfUrl String?   @db.Text
  displayOrder Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([actId, displayOrder, eventDate])
  @@index([eventType, eventDate])
}

model LegalActRelation {
  id            String   @id @default(cuid())
  fromActId     String
  toActId       String
  relationType  String
  summary       String?  @db.Text
  effectiveFrom DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  fromAct       LegalAct @relation("LegalActRelationFrom", fields: [fromActId], references: [id], onDelete: Cascade)
  toAct         LegalAct @relation("LegalActRelationTo", fields: [toActId], references: [id], onDelete: Cascade)

  @@unique([fromActId, toActId, relationType])
  @@index([fromActId, relationType])
  @@index([toActId, relationType])
}

model LawSectionHistoryEntry {
  id           String     @id @default(cuid())
  lawSectionId String
  lawSection   LawSection @relation(fields: [lawSectionId], references: [id], onDelete: Cascade)
  title        String
  summary      String?    @db.Text
  entryType    String
  eventDate    DateTime?
  sourceLabel  String?
  sourceUrl    String?    @db.Text
  sourcePdfUrl String?    @db.Text
  displayOrder Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([lawSectionId, displayOrder, eventDate])
  @@index([entryType, eventDate])
}

model LawSectionAlias {
  id              String     @id @default(cuid())
  lawSectionId    String
  lawSection      LawSection @relation(fields: [lawSectionId], references: [id], onDelete: Cascade)
  alias           String
  normalizedAlias String
  locale          String?
  aliasType       String     @default("SEARCH")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([lawSectionId, normalizedAlias, locale])
  @@index([normalizedAlias])
  @@index([lawSectionId, aliasType])
}

model LawSectionCrosswalk {
  id            String     @id @default(cuid())
  fromSectionId String
  toSectionId   String
  relationType  String     @default("SUCCESSOR")
  summary       String?    @db.Text
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  fromSection   LawSection @relation("LawSectionCrosswalkFrom", fields: [fromSectionId], references: [id], onDelete: Cascade)
  toSection     LawSection @relation("LawSectionCrosswalkTo", fields: [toSectionId], references: [id], onDelete: Cascade)

  @@unique([fromSectionId, toSectionId, relationType])
  @@index([fromSectionId, relationType])
  @@index([toSectionId, relationType])
}

model LegalIssueTopic {
  id            String      @id @default(cuid())
  slug          String      @unique
  title         String
  description   String?     @db.Text
  searchKeywords String?    @db.Text
  acts          LegalAct[]
  sections      LawSection[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model SearchDocument {
  id           String   @id @default(cuid())
  documentType String
  entitySlug   String
  locale       String   @default("en")
  href         String
  title        String
  description  String?  @db.Text
  searchText   String   @db.Text
  rankBoost    Float    @default(1.0)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([documentType, entitySlug, locale])
  @@index([documentType, locale, isPublished])
}

model DocumentTemplate {
  id           String                        @id @default(cuid())
  title        String
  description  String
  category     String
  downloads    Int                           @default(0)
  content      String
  editorialStatus String                     @default("REVIEW")
  reviewerNotes  String?                     @db.Text
  reviewedAt     DateTime?
  reviewedById   String?
  reviewedBy     User?                       @relation("TemplateReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt    DateTime                      @default(now())
  updatedAt    DateTime                      @updatedAt
  translations DocumentTemplateTranslation[]
  reviewLogs   TemplateReviewLog[]
}

model LawyerVerificationCase {
  id                         String        @id @default(cuid())
  lawyerProfileId            String
  lawyerProfile              LawyerProfile @relation(fields: [lawyerProfileId], references: [id], onDelete: Cascade)
  submittedBarCouncilId      String?
  identityDocumentUrl        String?       @db.Text
  enrollmentCertificateUrl   String?       @db.Text
  practiceCertificateUrl     String?       @db.Text
  lawyerNotes                String?       @db.Text
  adminNotes                 String?       @db.Text
  status                     String        @default("UNDER_REVIEW")
  submittedAt                DateTime      @default(now())
  reviewedAt                 DateTime?
  reviewedById               String?
  reviewedBy                 User?         @relation("LawyerVerificationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt

  @@index([lawyerProfileId, submittedAt])
  @@index([status, submittedAt])
}

model TemplateReviewLog {
  id           String           @id @default(cuid())
  templateId    String
  template      DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  status        String
  notes         String?          @db.Text
  reviewedById  String?
  reviewedBy    User?            @relation("TemplateReviewLogReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt     DateTime         @default(now())

  @@index([templateId, createdAt])
  @@index([status, createdAt])
}

model FAQReviewLog {
  id           String   @id @default(cuid())
  faqId        String
  faq          FAQ      @relation(fields: [faqId], references: [id], onDelete: Cascade)
  status       String
  notes        String?  @db.Text
  reviewedById String?
  reviewedBy   User?    @relation("FAQReviewLogReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([faqId, createdAt])
  @@index([status, createdAt])
}

model GuideReviewLog {
  id           String     @id @default(cuid())
  guideId      String
  guide        GuideEntry @relation(fields: [guideId], references: [id], onDelete: Cascade)
  status       String
  notes        String?    @db.Text
  reviewedById String?
  reviewedBy   User?      @relation("GuideReviewLogReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())

  @@index([guideId, createdAt])
  @@index([status, createdAt])
}

model RightReviewLog {
  id           String     @id @default(cuid())
  rightId      String
  right        RightEntry @relation(fields: [rightId], references: [id], onDelete: Cascade)
  status       String
  notes        String?    @db.Text
  reviewedById String?
  reviewedBy   User?      @relation("RightReviewLogReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())

  @@index([rightId, createdAt])
  @@index([status, createdAt])
}

model LegalActReviewLog {
  id           String    @id @default(cuid())
  legalActId   String
  legalAct     LegalAct  @relation(fields: [legalActId], references: [id], onDelete: Cascade)
  status       String
  notes        String?   @db.Text
  reviewedById String?
  reviewedBy   User?     @relation("LegalActReviewLogReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())

  @@index([legalActId, createdAt])
  @@index([status, createdAt])
}

model LawSectionReviewLog {
  id           String     @id @default(cuid())
  lawSectionId String
  lawSection   LawSection @relation(fields: [lawSectionId], references: [id], onDelete: Cascade)
  status       String
  notes        String?    @db.Text
  reviewedById String?
  reviewedBy   User?      @relation("LawSectionReviewLogReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())

  @@index([lawSectionId, createdAt])
  @@index([status, createdAt])
}

model LanguageTranslation {
  id         String   @id @default(cuid())
  locale     String
  name       String
  languageId String
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([languageId, locale])
  @@index([locale])
}

model LawyerProfileTranslation {
  id              String        @id @default(cuid())
  locale          String
  bio             String?       @db.Text
  lawyerProfileId String
  lawyerProfile   LawyerProfile @relation(fields: [lawyerProfileId], references: [id], onDelete: Cascade)

  @@unique([lawyerProfileId, locale])
  @@index([locale])
}

model SpecializationTranslation {
  id               String         @id @default(cuid())
  locale           String
  name             String
  description      String?
  specializationId String
  specialization   Specialization @relation(fields: [specializationId], references: [id], onDelete: Cascade)

  @@unique([specializationId, locale])
  @@index([locale])
}

model FAQCategoryTranslation {
  id         String      @id @default(cuid())
  locale     String
  name       String
  description String?
  categoryId String
  category   FAQCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@index([locale])
}

model FAQTranslation {
  id      String @id @default(cuid())
  locale  String
  question String
  answer  String
  faqId   String
  faq     FAQ    @relation(fields: [faqId], references: [id], onDelete: Cascade)

  @@unique([faqId, locale])
  @@index([locale])
}

model DocumentTemplateTranslation {
  id         String           @id @default(cuid())
  locale     String
  title      String
  description String
  category   String
  content    String
  templateId String
  template   DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, locale])
  @@index([locale])
}
