generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role             String    @default("CITIZEN")
  consentTimestamp DateTime?
  consentVersion   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  lawyerProfile LawyerProfile?
  appointments  Appointment[]  @relation("CitizenAppointments")
  // NextAuth relations
  accounts      Account[]
  sessions      Session[]

  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  reviews          Review[]
  caseNotes        CaseNote[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model LawyerProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  city              String
  state             String?
  experienceYears   Int
  rating            Float    @default(0.0)
  reviewCount       Int      @default(0)
  consultationFee   Float
  consultationModes String[] // e.g., ["VIDEO", "CALL", "IN_PERSON"]
  profileViews      Int      @default(0)
  isVerified        Boolean  @default(false)
  barCouncilID      String?  @unique
  bio               String?  @db.Text
  subscriptionTier  String?  @default("BASIC") // BASIC, PRO, ELITE
  subscriptionExpiry DateTime?

  languages         Language[]
  specializations   Specialization[]
  modes             LawyerConsultationMode[]
  appointments      Appointment[] @relation("LawyerAppointments")
  reviews           Review[]      @relation("LawyerReviews")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Language {
  id      String          @id @default(cuid())
  name    String          @unique
  lawyers LawyerProfile[]
}

model Specialization {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  lawyers     LawyerProfile[]
}

model LawyerConsultationMode {
  id              String        @id @default(cuid())
  mode            String
  lawyerProfileId String
  lawyerProfile   LawyerProfile @relation(fields: [lawyerProfileId], references: [id], onDelete: Cascade)

  @@unique([mode, lawyerProfileId])
}

model Appointment {
  id                String        @id @default(cuid())
  citizenId         String
  lawyerId          String
  date              DateTime
  status            String        @default("PENDING")
  mode              String
  notes             String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  paymentStatus     String        @default("UNPAID")
  amount            Float?
  payoutStatus      String?       @default("PENDING") // PENDING, ELIGIBLE, SETTLED, DISPUTED
  citizen           User          @relation("CitizenAppointments", fields: [citizenId], references: [id])
  lawyer            LawyerProfile @relation("LawyerAppointments", fields: [lawyerId], references: [id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  messages          Message[]
  review            Review?
  caseNotes         CaseNote[] @relation("AppointmentCaseNotes")
}

model Message {
  id            String       @id @default(cuid())
  text          String       @db.Text
  senderId      String
  receiverId    String
  appointmentId String?
  fileUrl       String?      @db.Text
  fileName      String?
  createdAt     DateTime     @default(now())

  sender        User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver      User         @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([appointmentId])
}

model Review {
  id            String       @id @default(cuid())
  rating        Int
  comment       String?      @db.Text
  isDisputed    Boolean      @default(false)
  createdAt     DateTime     @default(now())

  appointmentId String       @unique
  lawyerId      String
  citizenId     String

  appointment   Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  lawyer        LawyerProfile @relation("LawyerReviews", fields: [lawyerId], references: [id], onDelete: Cascade)
  citizen       User         @relation(fields: [citizenId], references: [id], onDelete: Cascade)

  @@index([lawyerId])
  @@index([citizenId])
}

model CaseNote {
  id            String       @id @default(cuid())
  text          String       @db.Text
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  appointmentId String
  lawyerId      String

  appointment   Appointment  @relation("AppointmentCaseNotes", fields: [appointmentId], references: [id], onDelete: Cascade)
  lawyer        User         @relation(fields: [lawyerId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

model FAQCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  faqs        FAQ[]
}

model FAQ {
  id         String      @id @default(cuid())
  question   String
  answer     String
  categoryId String
  category   FAQCategory @relation(fields: [categoryId], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model DocumentTemplate {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  downloads   Int      @default(0)
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
