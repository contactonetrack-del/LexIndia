generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("CITIZEN")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  lawyerProfile LawyerProfile?
  appointments  Appointment[]  @relation("CitizenAppointments")
  // NextAuth relations
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model LawyerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  city            String
  experienceYears Int
  rating          Float    @default(0.0)
  reviewCount     Int      @default(0)
  consultationFee Float
  isVerified      Boolean  @default(false)
  barCouncilID    String?  @unique
  bio             String?

  languages       Language[]
  specializations Specialization[]
  modes           LawyerConsultationMode[]
  appointments    Appointment[] @relation("LawyerAppointments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Language {
  id      String          @id @default(cuid())
  name    String          @unique
  lawyers LawyerProfile[]
}

model Specialization {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  lawyers     LawyerProfile[]
}

model LawyerConsultationMode {
  id              String        @id @default(cuid())
  mode            String
  lawyerProfileId String
  lawyerProfile   LawyerProfile @relation(fields: [lawyerProfileId], references: [id], onDelete: Cascade)

  @@unique([mode, lawyerProfileId])
}

model Appointment {
  id        String        @id @default(cuid())
  citizenId String
  lawyerId  String
  date      DateTime
  status    String        @default("PENDING")
  mode      String
  notes     String?
  citizen   User          @relation("CitizenAppointments", fields: [citizenId], references: [id])
  lawyer    LawyerProfile @relation("LawyerAppointments", fields: [lawyerId], references: [id])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model FAQCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  faqs        FAQ[]
}

model FAQ {
  id         String      @id @default(cuid())
  question   String
  answer     String
  categoryId String
  category   FAQCategory @relation(fields: [categoryId], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model DocumentTemplate {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  downloads   Int      @default(0)
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
